{
  "manifest_version": 3,
  "name": "Volume Control",
  "version": "1.0.0",
  "description": "Per-tab volume control — mute, duck, or boost any tab",
  "permissions": ["tabs", "storage", "scripting", "tabCapture", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Volume Control",
    "default_icon": {
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  }
}
